# ============================================================================
# CRON JOBS — Avtomatski sistem agentov
# ============================================================================
#
# NAMESTITEV:
# 1. Odpri terminal
# 2. Vtipkaj: crontab -e
# 3. Kopiraj spodnje vrstice
# 4. Shrani (Ctrl+O, Enter, Ctrl+X)
#
# ============================================================================

# Format:
# minuta ura dan mesec dan_v_tednu ukaz

# ============================================================================
# OB 06:00 — Jutranji pregled (vsak dan)
# ============================================================================
00 06 * * * /root/.openclaw/workspace/construction-quote-app/agents/daily-check.sh >> /root/.openclaw/workspace/construction-quote-app/agents/logs/morning-check.log 2>&1

# Pošlji summary Roku (če je mail nastavljen)
# 00 06 * * * echo "Agenti so opravili jutranji pregled. Preveri logs/morning-check.log" | mail -s "Agent Report" rok@example.com 2>/dev/null || true

# ============================================================================
# OB 12:00 — Opoldanski pregled (vsak dan)
# ============================================================================
00 12 * * * /root/.openclaw/workspace/construction-quote-app/agents/daily-check.sh >> /root/.openclaw/workspace/construction-quote-app/agents/logs/noon-check.log 2>&1

# ============================================================================
# OB 18:00 — Večerni pregled (vsak dan)
# ============================================================================
00 18 * * * /root/.openclaw/workspace/construction-quote-app/agents/daily-check.sh >> /root/.openclaw/workspace/construction-quote-app/agents/logs/evening-check.log 2>&1

# Generiraj dnevni report
05 18 * * * /root/.openclaw/workspace/construction-quote-app/agents/generate-daily-report.sh >> /root/.openclaw/workspace/construction-quote-app/agents/logs/report-generation.log 2>&1

# ============================================================================
# OB 03:00 — Nightly maintenance (vsak dan)
# ============================================================================
# Backup baze
00 03 * * * cp /root/.openclaw/workspace/construction-quote-app/data/quotes.db /root/.openclaw/workspace/construction-quote-app/backups/quotes_$(date +\%Y\%m\%d).db

# Očisti stare backupe (hrani samo zadnjih 30)
05 03 * * * find /root/.openclaw/workspace/construction-quote-app/backups -name "quotes_*.db" -mtime +30 -delete

# Preveri velikost baze
10 03 * * * /root/.openclaw/workspace/construction-quote-app/agents/check-db-size.sh >> /root/.openclaw/workspace/construction-quote-app/agents/logs/db-check.log 2>&1

# ============================================================================
# OB NEDELJO 23:00 — Tedenski report
# ============================================================================
00 23 * * 0 /root/.openclaw/workspace/construction-quote-app/agents/generate-weekly-report.sh >> /root/.openclaw/workspace/construction-quote-app/agents/logs/weekly-report.log 2>&1

# ============================================================================
# OB 1. V MESQECU 09:00 — Mesečni report
# ============================================================================
00 09 1 * * /root/.openclaw/workspace/construction-quote-app/agents/generate-monthly-report.sh >> /root/.openclaw/workspace/construction-quote-app/agents/logs/monthly-report.log 2>&1

# ============================================================================
# POMOČ:
# =====
# Za pregled cron jobov: crontab -l
# Za brisanje vseh: crontab -r
# Za urejanje: crontab -e
#
# Časovne oznake:
# * = vsaka vrednost
# / = korak (npr. */12 = vsakih 12 ur)
# , = seznam (npr. 1,2,3)
# - = razpon (npr. 1-5)
#
# ============================================================================
